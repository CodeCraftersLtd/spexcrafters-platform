{
  "space": {
    "$description": "4px base spacing scale (design-system.md §4.1)",
    "0": { "$type": "dimension", "$value": "0" },
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "16": { "$type": "dimension", "$value": "64px" },
    "20": { "$type": "dimension", "$value": "80px" },
    "24": { "$type": "dimension", "$value": "96px" },
    "32": { "$type": "dimension", "$value": "128px" }
  },
  "radius": {
    "$description": "Restrained radii — no radius above 8px anywhere (design-system.md §4.2)",
    "none": { "$type": "dimension", "$value": "0" },
    "xs": { "$type": "dimension", "$value": "2px" },
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "6px" },
    "lg": { "$type": "dimension", "$value": "8px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "$description": "Borders first; shadows for true overlays only (design-system.md §4.3)",
    "0": { "$type": "shadow", "$value": "none" },
    "1": { "$type": "shadow", "$value": "0 1px 2px rgb(12 14 18 / 0.06)" },
    "2": { "$type": "shadow", "$value": "0 2px 8px rgb(12 14 18 / 0.10)" },
    "3": { "$type": "shadow", "$value": "0 8px 24px rgb(12 14 18 / 0.14)" },
    "4": { "$type": "shadow", "$value": "0 16px 48px rgb(12 14 18 / 0.18)" }
  },
  "border": {
    "$description": "Border/hairline system (design-system.md §4.4) — composite CSS values referencing semantic color tokens",
    "hairline": { "$type": "border", "$value": "1px solid var(--sc-color-border-decorative)" },
    "strong": { "$type": "border", "$value": "1px solid var(--sc-color-border-strong)" },
    "selected": { "$type": "border", "$value": "2px solid var(--sc-color-action-primary)" },
    "error": { "$type": "border", "$value": "1px solid var(--sc-color-status-danger)" }
  },
  "z": {
    "$description": "Z-index scale — arbitrary z-index values in component CSS are a lint error (design-system.md §4.5)",
    "base": { "$type": "number", "$value": 0 },
    "raised": { "$type": "number", "$value": 10 },
    "sticky": { "$type": "number", "$value": 100 },
    "header": { "$type": "number", "$value": 200 },
    "dropdown": { "$type": "number", "$value": 1000 },
    "overlay": { "$type": "number", "$value": 1300 },
    "modal": { "$type": "number", "$value": 1400 },
    "popover": { "$type": "number", "$value": 1500 },
    "toast": { "$type": "number", "$value": 1600 },
    "tooltip": { "$type": "number", "$value": 1700 }
  },
  "grid": {
    "max": { "$type": "dimension", "$value": "1320px" }
  },
  "bp": {
    "$description": "Breakpoints — media queries for page scaffolding, container queries for components (design-system.md §4.7)",
    "sm": { "$type": "dimension", "$value": "480px" },
    "md": { "$type": "dimension", "$value": "768px" },
    "lg": { "$type": "dimension", "$value": "1024px" },
    "xl": { "$type": "dimension", "$value": "1280px" },
    "2xl": { "$type": "dimension", "$value": "1536px" }
  }
}
