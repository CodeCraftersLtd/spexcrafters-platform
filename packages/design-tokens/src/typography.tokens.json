{
  "font": {
    "display": { "$type": "fontFamily", "$value": "\"Archivo\", var(--sc-font-fallback-sans)" },
    "ui": { "$type": "fontFamily", "$value": "\"Instrument Sans\", var(--sc-font-fallback-sans)" },
    "mono": { "$type": "fontFamily", "$value": "\"IBM Plex Mono\", ui-monospace, \"SFMono-Regular\", Menlo, Consolas, monospace" },
    "fallback-sans": { "$type": "fontFamily", "$value": "-apple-system, \"Segoe UI\", system-ui, Arial, sans-serif" },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    }
  },
  "text": {
    "$description": "Fluid type scale — rem-based with viewport interpolation only (design-system.md §3.2)",
    "2xs": { "$type": "dimension", "$value": "0.6875rem" },
    "xs": { "$type": "dimension", "$value": "0.75rem" },
    "sm": { "$type": "dimension", "$value": "0.875rem" },
    "md": { "$type": "dimension", "$value": "clamp(0.9375rem, 0.9rem + 0.2vw, 1rem)" },
    "lg": { "$type": "dimension", "$value": "clamp(1.0625rem, 1rem + 0.35vw, 1.1875rem)" },
    "xl": { "$type": "dimension", "$value": "clamp(1.25rem, 1.15rem + 0.5vw, 1.5rem)" },
    "2xl": { "$type": "dimension", "$value": "clamp(1.5rem, 1.3rem + 1vw, 2rem)" },
    "3xl": { "$type": "dimension", "$value": "clamp(1.875rem, 1.5rem + 1.8vw, 2.75rem)" },
    "4xl": { "$type": "dimension", "$value": "clamp(2.375rem, 1.8rem + 2.8vw, 3.75rem)" },
    "display": { "$type": "dimension", "$value": "clamp(2.75rem, 2rem + 4vw, 5.25rem)" }
  },
  "leading": {
    "tight": { "$type": "number", "$value": 1.15 },
    "snug": { "$type": "number", "$value": 1.3 },
    "body": { "$type": "number", "$value": 1.55 },
    "ui": { "$type": "number", "$value": 1.4 }
  },
  "tracking": {
    "display": { "$type": "dimension", "$value": "-0.015em" },
    "normal": { "$type": "number", "$value": 0 },
    "caps": { "$type": "dimension", "$value": "0.06em" },
    "mono": { "$type": "number", "$value": 0 }
  }
}
