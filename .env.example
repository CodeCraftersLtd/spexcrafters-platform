# ==============================================================================
# SpexCrafters — environment template
# Copy to .env for local development. NEVER commit real secrets (gitleaks-scanned).
# Docker Compose (infrastructure/docker/compose.yaml) provides matching defaults.
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend (apps/api — Spring Boot)
# ------------------------------------------------------------------------------
# PostgreSQL (system of record). Compose service: postgres:17 on 5432.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/spexcrafters
SPRING_DATASOURCE_USERNAME=spexcrafters
SPRING_DATASOURCE_PASSWORD=spexcrafters_dev

# JWT access-token signing secret (HS256, Sprint-1 scheme per ADR-006).
# Minimum 32 bytes (enforced at startup). DEV ONLY value; production uses the
# secret manager. Generate:  openssl rand -base64 48
SPEXCRAFTERS_JWT_SECRET=dev-only-change-me-generate-48-bytes-of-entropy-first

# SMTP for transactional email. Dev: Mailpit (compose) — UI at http://localhost:8025
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPEXCRAFTERS_MAIL_FROM=no-reply@spexcrafters.com

# Absolute base URL of the web app (used in verification-email links).
SPEXCRAFTERS_WEB_BASE_URL=http://localhost:3000

# CORS allowlist for the API (comma-separated origins).
SPEXCRAFTERS_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Redis (rate limiting / locks; Sprint-1 uses DB-backed brute-force checks,
# Redis reserved for the rate-limiter that lands with the marketplace phases).
REDIS_URL=redis://localhost:6379

# S3-compatible object storage. Dev: MinIO (compose) — console at http://localhost:9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=spexcrafters
S3_SECRET_KEY=spexcrafters_dev
S3_BUCKET_MEDIA=spexcrafters-media
# Private bucket holding supplier verification evidence (Phase 7, ADR-023). Never public.
S3_BUCKET_EVIDENCE=spexcrafters-evidence
# Path-style addressing is required by MinIO; harmless on AWS S3.
S3_PATH_STYLE_ACCESS=true

# ------------------------------------------------------------------------------
# Frontend (apps/web — Next.js BFF)
# ------------------------------------------------------------------------------
# Server-side base URL of the API (the browser never calls the API directly).
API_BASE_URL=http://localhost:8080/api/v1

# Session-cookie encryption key (JWE A256GCM). Exactly 32 bytes, base64. Generate:
#   openssl rand -base64 32
SESSION_SECRET=dev-only-generate-32-bytes-base64-encoded=

# Public site origin (metadata, canonical URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Browser-facing object-storage origin for direct-to-storage evidence uploads.
# Added to the CSP connect-src (ADR-023/ADR-017). Local dev = MinIO on :9000;
# production = the S3/R2/CDN origin. Empty ⇒ evidence upload blocked by CSP.
NEXT_PUBLIC_STORAGE_ORIGIN=http://localhost:9000

# ------------------------------------------------------------------------------
# Observability (optional locally)
# ------------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=spexcrafters-api
