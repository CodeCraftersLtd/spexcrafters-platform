# Upstream SpexCrafters API (Spring Boot). Defaults to the local dev server.
API_BASE_URL=http://localhost:8080/api/v1

# 32 random bytes, base64-encoded — encrypts the sc_session cookie (JWE dir/A256GCM).
# Generate with:  node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Canonical origin of this app, used for absolute metadata URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
