{
  "openapi": "3.1.0",
  "info": {
    "title": "SpexCrafters API",
    "description": "REST API for the SpexCrafters Global B2B Optical Marketplace and Sourcing Platform. Sprint 1 surface: identity vertical slice (registration, email verification, login, token refresh, logout, current user). This committed spec is the contract of record; the Spring Boot application must produce a compatible document (validated in CI), and the TypeScript client in packages/api-client is generated from it.",
    "version": "0.1.0",
    "contact": { "name": "SpexCrafters Engineering" }
  },
  "servers": [
    { "url": "http://localhost:8080/api/v1", "description": "Local development" },
    { "url": "https://api.spexcrafters.com/api/v1", "description": "Production (working domain, pending OQ-8 confirmation)" }
  ],
  "tags": [
    { "name": "auth", "description": "Registration, email verification, and session tokens" },
    { "name": "me", "description": "Current authenticated user" },
    { "name": "organizations", "description": "Organization tenancy: creation, membership, roles, invitations. Non-members receive 404 for org resources (existence concealment); members lacking a capability receive 403. See docs/architecture/organizations-capability-model.md." }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["auth"],
        "operationId": "register",
        "summary": "Register a new user account",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RegisterRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Account created; verification email dispatched.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RegisterResponse" } } }
          },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/ValidationError" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/auth/verify-email": {
      "post": {
        "tags": ["auth"],
        "operationId": "verifyEmail",
        "summary": "Confirm an email address with a single-use token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/VerifyEmailRequest" } }
          }
        },
        "responses": {
          "204": { "description": "Email verified. Idempotent for an already-consumed token belonging to a verified user." },
          "410": { "$ref": "#/components/responses/TokenGone" },
          "422": { "$ref": "#/components/responses/ValidationError" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/auth/resend-verification": {
      "post": {
        "tags": ["auth"],
        "operationId": "resendVerification",
        "summary": "Re-send the verification email",
        "description": "Uniform 202 regardless of account existence or state — no account enumeration.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ResendVerificationRequest" } }
          }
        },
        "responses": {
          "202": { "description": "Accepted. If a matching unverified account exists, an email is sent." },
          "422": { "$ref": "#/components/responses/ValidationError" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["auth"],
        "operationId": "login",
        "summary": "Authenticate with email and password",
        "description": "Returns a short-lived bearer access token and an opaque rotating refresh token. Consumed exclusively by the web BFF, which holds tokens server-side and issues an HttpOnly session cookie to the browser. Sprint-1 password grant; Authorization Code + PKCE via Spring Authorization Server is the planned Sprint-2 upgrade (ADR-006).",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TokenResponse" } } }
          },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "403": { "$ref": "#/components/responses/EmailNotVerified" },
          "422": { "$ref": "#/components/responses/ValidationError" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["auth"],
        "operationId": "refreshTokens",
        "summary": "Exchange a refresh token for a new token pair",
        "description": "Refresh tokens are single-use and rotate on every call; reuse of a consumed token revokes the whole family (theft detection).",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RefreshRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "New token pair.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TokenResponse" } } }
          },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["auth"],
        "operationId": "logout",
        "summary": "Revoke a refresh-token family",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RefreshRequest" } }
          }
        },
        "responses": {
          "204": { "description": "Revoked (idempotent)." },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/me": {
      "get": {
        "tags": ["me"],
        "operationId": "getCurrentUser",
        "summary": "Return the authenticated user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserSummary" } } }
          },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" }
        }
      }
    },
    "/me/organizations": {
      "get": {
        "tags": ["organizations"],
        "operationId": "listMyOrganizations",
        "summary": "List the caller's active organization memberships",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Memberships of the authenticated user.",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/MyMembership" } } } }
          },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" }
        }
      }
    },
    "/organizations": {
      "post": {
        "tags": ["organizations"],
        "operationId": "createOrganization",
        "summary": "Create an organization; the caller becomes its initial OWNER atomically",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateOrganizationRequest" } } }
        },
        "responses": {
          "201": {
            "description": "Created. Includes the caller's role and resolved capabilities.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OrganizationResponse" } } }
          },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "422": { "$ref": "#/components/responses/ValidationError" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/organizations/{organizationId}": {
      "parameters": [{ "name": "organizationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get": {
        "tags": ["organizations"],
        "operationId": "getOrganization",
        "summary": "Fetch an organization (requires organization.read)",
        "description": "Non-members receive 404 (existence concealment); members lacking a capability receive 403.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Organization.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OrganizationResponse" } } } },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["organizations"],
        "operationId": "updateOrganization",
        "summary": "Update organization profile (requires organization.update; optimistic locking via version)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateOrganizationRequest" } } }
        },
        "responses": {
          "200": { "description": "Updated organization.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OrganizationResponse" } } } },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/organizations/{organizationId}/members": {
      "parameters": [{ "name": "organizationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get": {
        "tags": ["organizations"],
        "operationId": "listMembers",
        "summary": "List active members (requires organization.members.read)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Active members.", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/MemberResponse" } } } } },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/members/{membershipId}": {
      "parameters": [
        { "name": "organizationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
        { "name": "membershipId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
      ],
      "delete": {
        "tags": ["organizations"],
        "operationId": "removeMember",
        "summary": "Remove a member (requires organization.members.remove; rank rules; last-owner protected; self-removal allowed except last owner)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "Removed." },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/organizations/{organizationId}/members/{membershipId}/role": {
      "parameters": [
        { "name": "organizationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
        { "name": "membershipId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
      ],
      "put": {
        "tags": ["organizations"],
        "operationId": "changeMemberRole",
        "summary": "Change a member's role (requires organization.roles.manage — OWNER only; self-change forbidden; last-owner protected)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChangeRoleRequest" } } }
        },
        "responses": {
          "200": { "description": "Updated membership.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MemberResponse" } } } },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/organizations/{organizationId}/invitations": {
      "parameters": [{ "name": "organizationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get": {
        "tags": ["organizations"],
        "operationId": "listInvitations",
        "summary": "List invitations (requires organization.members.read)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Invitations.", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/InvitationResponse" } } } } },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "tags": ["organizations"],
        "operationId": "createInvitation",
        "summary": "Invite by email (requires organization.members.invite; ADMIN may invite MEMBER role only; raw token delivered solely via email)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateInvitationRequest" } } }
        },
        "responses": {
          "201": { "description": "Invitation created and email dispatched.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/InvitationResponse" } } } },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/ValidationError" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/organizations/{organizationId}/invitations/{invitationId}/revoke": {
      "parameters": [
        { "name": "organizationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
        { "name": "invitationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
      ],
      "post": {
        "tags": ["organizations"],
        "operationId": "revokeInvitation",
        "summary": "Revoke a pending invitation (requires organization.members.invite; idempotent for already-revoked)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "Revoked (idempotent)." },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "410": { "$ref": "#/components/responses/TokenGone" }
        }
      }
    },
    "/invitations/accept": {
      "post": {
        "tags": ["organizations"],
        "operationId": "acceptInvitation",
        "summary": "Accept an invitation token (authenticated; account email must match the invitation; single-use)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AcceptInvitationRequest" } } }
        },
        "responses": {
          "200": { "description": "Membership created.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MyMembership" } } } },
          "401": { "$ref": "#/components/responses/AuthenticationFailed" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "410": { "$ref": "#/components/responses/TokenGone" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password", "displayName"],
        "properties": {
          "email": { "type": "string", "format": "email", "maxLength": 254 },
          "password": {
            "type": "string",
            "minLength": 12,
            "maxLength": 128,
            "description": "Minimum 12 characters; checked against the platform password policy server-side. Paste always permitted (WCAG 3.3.8)."
          },
          "displayName": { "type": "string", "minLength": 1, "maxLength": 120 },
          "locale": { "$ref": "#/components/schemas/Locale" }
        }
      },
      "RegisterResponse": {
        "type": "object",
        "required": ["userId"],
        "properties": {
          "userId": { "type": "string", "format": "uuid", "description": "UUIDv7" }
        }
      },
      "VerifyEmailRequest": {
        "type": "object",
        "required": ["token"],
        "properties": { "token": { "type": "string", "minLength": 32, "maxLength": 512 } }
      },
      "ResendVerificationRequest": {
        "type": "object",
        "required": ["email"],
        "properties": { "email": { "type": "string", "format": "email", "maxLength": 254 } }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "maxLength": 254 },
          "password": { "type": "string", "minLength": 1, "maxLength": 128 }
        }
      },
      "RefreshRequest": {
        "type": "object",
        "required": ["refreshToken"],
        "properties": { "refreshToken": { "type": "string", "minLength": 32, "maxLength": 512 } }
      },
      "TokenResponse": {
        "type": "object",
        "required": ["accessToken", "tokenType", "expiresIn", "refreshToken", "user"],
        "properties": {
          "accessToken": { "type": "string", "description": "JWT, ~10 minute lifetime" },
          "tokenType": { "type": "string", "const": "Bearer" },
          "expiresIn": { "type": "integer", "description": "Access-token lifetime in seconds" },
          "refreshToken": { "type": "string", "description": "Opaque, single-use, rotating; stored hashed server-side" },
          "user": { "$ref": "#/components/schemas/UserSummary" }
        }
      },
      "UserSummary": {
        "type": "object",
        "required": ["id", "email", "displayName", "locale", "emailVerified", "createdAt"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email" },
          "displayName": { "type": "string" },
          "locale": { "$ref": "#/components/schemas/Locale" },
          "emailVerified": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Locale": {
        "type": "string",
        "enum": ["en", "zh-Hans", "fr", "de"],
        "default": "en",
        "description": "Clients must tolerate unknown future values."
      },
      "OrganizationType": {
        "type": "string",
        "enum": ["BUYER", "SUPPLIER", "HYBRID"],
        "description": "Clients must tolerate unknown future values."
      },
      "OrganizationRole": {
        "type": "string",
        "enum": ["OWNER", "ADMIN", "MEMBER"],
        "description": "Rank order OWNER > ADMIN > MEMBER; see organizations-capability-model.md."
      },
      "Capability": {
        "type": "string",
        "enum": [
          "organization.read",
          "organization.update",
          "organization.members.read",
          "organization.members.invite",
          "organization.members.remove",
          "organization.roles.manage"
        ],
        "description": "Typed capabilities; clients must tolerate unknown future values."
      },
      "InvitationStatus": {
        "type": "string",
        "enum": ["PENDING", "ACCEPTED", "REVOKED", "EXPIRED"]
      },
      "CreateOrganizationRequest": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 120 },
          "type": { "$ref": "#/components/schemas/OrganizationType" },
          "country": { "type": "string", "minLength": 2, "maxLength": 2, "description": "ISO 3166-1 alpha-2, uppercase" }
        }
      },
      "UpdateOrganizationRequest": {
        "type": "object",
        "required": ["version"],
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 120 },
          "country": { "type": "string", "minLength": 2, "maxLength": 2 },
          "version": { "type": "integer", "description": "Optimistic-locking version from the last read; mismatch → 409" }
        }
      },
      "OrganizationResponse": {
        "type": "object",
        "required": ["id", "name", "type", "createdAt", "version", "callerRole", "callerCapabilities"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "type": { "$ref": "#/components/schemas/OrganizationType" },
          "country": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "version": { "type": "integer" },
          "callerRole": { "$ref": "#/components/schemas/OrganizationRole" },
          "callerCapabilities": { "type": "array", "items": { "$ref": "#/components/schemas/Capability" } }
        }
      },
      "MyMembership": {
        "type": "object",
        "required": ["membershipId", "organizationId", "organizationName", "organizationType", "role", "joinedAt"],
        "properties": {
          "membershipId": { "type": "string", "format": "uuid" },
          "organizationId": { "type": "string", "format": "uuid" },
          "organizationName": { "type": "string" },
          "organizationType": { "$ref": "#/components/schemas/OrganizationType" },
          "role": { "$ref": "#/components/schemas/OrganizationRole" },
          "joinedAt": { "type": "string", "format": "date-time" }
        }
      },
      "MemberResponse": {
        "type": "object",
        "required": ["membershipId", "userId", "displayName", "email", "role", "joinedAt"],
        "properties": {
          "membershipId": { "type": "string", "format": "uuid" },
          "userId": { "type": "string", "format": "uuid" },
          "displayName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "$ref": "#/components/schemas/OrganizationRole" },
          "joinedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ChangeRoleRequest": {
        "type": "object",
        "required": ["role"],
        "properties": { "role": { "$ref": "#/components/schemas/OrganizationRole" } }
      },
      "CreateInvitationRequest": {
        "type": "object",
        "required": ["email", "role"],
        "properties": {
          "email": { "type": "string", "format": "email", "maxLength": 254 },
          "role": {
            "type": "string",
            "enum": ["ADMIN", "MEMBER"],
            "description": "OWNER cannot be invited; promote after joining. ADMIN actors may set MEMBER only."
          }
        }
      },
      "InvitationResponse": {
        "type": "object",
        "required": ["id", "email", "role", "status", "expiresAt", "createdAt"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["ADMIN", "MEMBER"] },
          "status": { "$ref": "#/components/schemas/InvitationStatus" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "AcceptInvitationRequest": {
        "type": "object",
        "required": ["token"],
        "properties": { "token": { "type": "string", "minLength": 32, "maxLength": 512 } }
      },
      "Problem": {
        "type": "object",
        "description": "RFC 9457 problem details. Content type application/problem+json.",
        "required": ["type", "title", "status"],
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string" },
          "instance": { "type": "string" },
          "correlationId": { "type": "string" },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["field", "code", "message"],
              "properties": {
                "field": { "type": "string" },
                "code": { "type": "string" },
                "message": { "type": "string", "description": "Locale-resolved; code maps to frontend i18n keys" }
              }
            }
          }
        }
      }
    },
    "responses": {
      "ValidationError": {
        "description": "Request failed validation.",
