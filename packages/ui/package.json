{
  "name": "@spexcrafters/ui",
  "version": "0.1.0",
  "description": "SpexCrafters UI primitives — token-skinned React components (CSS Modules, WCAG 2.2 AA)",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"ui: stylelint/eslint wiring lands with the lint sprint\"",
    "build": "echo \"ui: consumed from source via Next transpilePackages — no build step\""
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@spexcrafters/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@spexcrafters/config": "workspace:*",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^8.6.14",
    "typescript": "^5.7.3",
    "vite": "^6.4.3",
    "vitest": "^3.0.5"
  }
}
